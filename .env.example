# =============================================================================
# SmartTalker — Environment Variables
# Phase 1: DashScope (Qwen3 LLM/ASR/TTS) + RunPod Serverless + Cloudflare R2
# Copy to .env and fill in your values: cp .env.example .env
# =============================================================================

# ── General ──────────────────────────────────────────────────────────────────
APP_NAME=Maskki
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# ── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
# CORS: "*" for dev, comma-separated origins for production
CORS_ORIGINS=*
# API authentication key (REQUIRED in production) — generate: openssl rand -hex 32
API_KEY=
# Admin API key for /admin/* endpoints — generate: openssl rand -hex 32
ADMIN_API_KEY=
# Rate limit per IP per minute
RATE_LIMIT_PER_MINUTE=60
# Max seconds for a single pipeline request
PIPELINE_TIMEOUT=120

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Generate a strong password: openssl rand -base64 32
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+asyncpg://smarttalker:${POSTGRES_PASSWORD}@postgres:5432/smarttalker

# ── DashScope (shared API key for Qwen3 LLM, ASR, TTS) ─────────────────────
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_WS_URL=wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime

# ── ASR (DashScope Qwen3 Speech Recognition) ─────────────────────────────────
ASR_MODEL=qwen3-asr-flash-realtime

# ── LLM (DashScope Qwen3 Language Model) ─────────────────────────────────────
LLM_MODEL_NAME=qwen3-max
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=${DASHSCOPE_API_KEY}
LLM_TIMEOUT=30
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7
LLM_MAX_HISTORY=10

# ── TTS (DashScope Qwen3 Voice Cloning) ──────────────────────────────────────
TTS_MODEL=qwen3-tts-vc-realtime
TTS_SAMPLE_RATE=48000
TTS_MAX_TEXT_LENGTH=1000

# ── RunPod Serverless (GPU Rendering) ────────────────────────────────────────
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_MUSETALK=
RUNPOD_ENDPOINT_PREPROCESS=

# ── Cloudflare R2 (S3-compatible Storage) ────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=maskki-media
R2_PUBLIC_URL=
R2_ENDPOINT_URL=https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com

# ── Redis ────────────────────────────────────────────────────────────────────
# Generate a strong password: openssl rand -base64 32
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_TTL=3600

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_BASE_DIR=./outputs
STORAGE_MAX_FILE_AGE_HOURS=24
STATIC_FILES_DIR=./files

# ── Avatar Clips ─────────────────────────────────────────────────────────────
CLIPS_DIR=./clips

# ── Knowledge Base (RAG) ────────────────────────────────────────────────────
KB_ENABLED=true
KB_STORAGE_DIR=./data/kb
KB_EMBEDDING_MODEL=text-embedding-v3
KB_EMBEDDING_API_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
KB_EMBEDDING_API_KEY=${DASHSCOPE_API_KEY}
KB_CHUNK_SIZE=500
KB_CHUNK_OVERLAP=50
KB_TOP_K=3
KB_CONFIDENCE_THRESHOLD=0.6

# ── Training Engine ─────────────────────────────────────────────────────────
TRAINING_ENABLED=true
TRAINING_DB_PATH=./data/training.db
TRAINING_ESCALATION_THRESHOLD=0.5
TRAINING_GO_LIVE_THRESHOLD=100.0

# ── Guardrails ───────────────────────────────────────────────────────────────
GUARDRAILS_ENABLED=true
GUARDRAILS_MAX_RESPONSE_LENGTH=2000
GUARDRAILS_BLOCKED_TOPICS=
GUARDRAILS_REQUIRED_DISCLAIMERS=

# ── Billing ──────────────────────────────────────────────────────────────────
BILLING_ENABLED=true
BILLING_RATE_PER_SECOND=0.002
BILLING_GRACE_PERIOD_S=5
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT=sandbox

# ── WhatsApp (Meta Business API) — optional ──────────────────────────────────
# Generate a random verify token: openssl rand -hex 32
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v18.0
WHATSAPP_WEBHOOK_URL=

# ── Telegram (Bot API) — optional ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_URL=

# ── WebRTC — optional ────────────────────────────────────────────────────────
WEBRTC_ENABLED=false
WEBRTC_STUN_SERVERS=stun:stun.l.google.com:19302
WEBRTC_TURN_SERVER=
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_PASSWORD=

# ── AI Optimization Agent ────────────────────────────────────────────────────
# Note: AgentSettings uses env_prefix="AGENT_" — AGENT_ENABLED maps to agent_enabled
AGENT_ENABLED=true
AGENT_AUTO_FIX_ENABLED=true
AGENT_SCAN_INTERVAL_S=60
AGENT_AUDIT_LOG_PATH=./logs/agent_audit.jsonl
AGENT_NOTIFICATION_EMAIL_ENABLED=true
AGENT_NOTIFICATION_EMAIL_TO=contact@lsmarttech.com
AGENT_NOTIFICATION_WS_ENABLED=true

# ── SMTP (email alerts) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=agent@maskki.com
SMTP_FROM_NAME=Maskki AI Agent
RESEND_API_KEY=

# ── Monitoring ───────────────────────────────────────────────────────────────
# Generate a strong password: openssl rand -base64 32
GRAFANA_ADMIN_PASSWORD=
GRAFANA_ROOT_URL=http://localhost/grafana

# ── Deployment ───────────────────────────────────────────────────────────────
DOMAIN_NAME=localhost
SSL_CERT_PATH=/etc/letsencrypt/live/localhost/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/localhost/privkey.pem
