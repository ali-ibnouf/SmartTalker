# =============================================================================
# SmartTalker — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
# =============================================================================

# ── General ──────────────────────────────────────────────────────────────────
APP_NAME=SmartTalker
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# ── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
CORS_ORIGINS=*
# API authentication key (REQUIRED in production)
API_KEY=
# Admin API key for /admin/* endpoints
ADMIN_API_KEY=
# Rate limit per IP per minute
RATE_LIMIT_PER_MINUTE=60
# Max seconds for a single pipeline request
PIPELINE_TIMEOUT=120

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Generate a strong password: openssl rand -base64 32
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+asyncpg://smarttalker:${POSTGRES_PASSWORD}@postgres:5432/smarttalker

# ── ASR (FunASR SenseVoice, CPU) ─────────────────────────────────────────────
ASR_MODEL_ID=iic/SenseVoiceSmall
ASR_DEVICE=cpu
ASR_MODEL_DIR=./models/funasr

# ── LLM (Qwen via DashScope) ────────────────────────────────────────────────
LLM_MODEL_NAME=qwen-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_TIMEOUT=30
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7
LLM_MAX_HISTORY=10

# ── TTS (CosyVoice, CPU) ────────────────────────────────────────────────────
TTS_MODEL_ID=CosyVoice-300M-SFT
TTS_MODEL_DIR=./models/cosyvoice
TTS_DEVICE=cpu
TTS_SAMPLE_RATE=22050
TTS_DEFAULT_VOICE=default
TTS_MAX_TEXT_LENGTH=1000

# ── RunPod Serverless ───────────────────────────────────────────────────────
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_MUSETALK=
RUNPOD_ENDPOINT_PREPROCESS=

# ── Redis ────────────────────────────────────────────────────────────────────
# Generate a strong password: openssl rand -base64 32
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_TTL=3600

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_BASE_DIR=./outputs
STORAGE_MAX_FILE_AGE_HOURS=24
STATIC_FILES_DIR=./files

# ── Avatar Clips ─────────────────────────────────────────────────────────────
CLIPS_DIR=./clips

# ── Knowledge Base (RAG) ────────────────────────────────────────────────────
KB_ENABLED=true
KB_STORAGE_DIR=./data/kb
KB_EMBEDDING_MODEL=text-embedding-v3
KB_EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
KB_EMBEDDING_API_KEY=
KB_CHUNK_SIZE=500
KB_CHUNK_OVERLAP=50
KB_TOP_K=3
KB_CONFIDENCE_THRESHOLD=0.6

# ── Training Engine ─────────────────────────────────────────────────────────
TRAINING_ENABLED=true
TRAINING_DB_PATH=./data/training.db
TRAINING_ESCALATION_THRESHOLD=0.5
TRAINING_GO_LIVE_THRESHOLD=100.0

# ── Billing ──────────────────────────────────────────────────────────────────
BILLING_ENABLED=true
BILLING_RATE_PER_SECOND=0.001
BILLING_GRACE_PERIOD_S=5

# ── WhatsApp (Meta Business API) ─────────────────────────────────────────────
# Generate a random verify token: openssl rand -hex 32
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v18.0
WHATSAPP_WEBHOOK_URL=

# ── WebRTC ───────────────────────────────────────────────────────────────────
WEBRTC_ENABLED=false
WEBRTC_STUN_SERVERS=stun:stun.l.google.com:19302

# ── Monitoring ─────────────────────────────────────────────────────────────
# Generate a strong password: openssl rand -base64 32
GRAFANA_ADMIN_PASSWORD=

# ── Deployment ───────────────────────────────────────────────────────────────
DOMAIN_NAME=localhost
SSL_CERT_PATH=/etc/letsencrypt/live/localhost/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/localhost/privkey.pem
