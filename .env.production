# =============================================================================
# SmartTalker — Production Environment Variables
# Phase 1: DashScope (Qwen3 LLM/ASR/TTS) + RunPod Serverless + Cloudflare R2
#
# Copy to .env on your production server: cp .env.production .env
# Fill in all values marked with CHANGEME
# =============================================================================

# ── General ──────────────────────────────────────────────────────────────────
APP_NAME=SmartTalker
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# ── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
# CORS: comma-separated list of allowed origins (NO wildcard in production)
CORS_ORIGINS=https://admin.yourdomain.com,https://app.yourdomain.com,https://yourdomain.com
# API authentication key — generate: openssl rand -hex 32
API_KEY=CHANGEME
# Admin API key for /admin/* endpoints — generate: openssl rand -hex 32
ADMIN_API_KEY=CHANGEME
# Rate limit per IP per minute
RATE_LIMIT_PER_MINUTE=60
# Max seconds for a single pipeline request
PIPELINE_TIMEOUT=120

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Generate a strong password: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGEME
DATABASE_URL=postgresql+asyncpg://smarttalker:${POSTGRES_PASSWORD}@postgres:5432/smarttalker

# ── DashScope (shared API key for LLM, ASR, TTS) ────────────────────────────
DASHSCOPE_API_KEY=CHANGEME
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_WS_URL=wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime

# ── ASR (DashScope Qwen3 Speech Recognition) ─────────────────────────────────
ASR_MODEL=qwen3-asr-flash-realtime

# ── LLM (DashScope Qwen3 Language Model) ─────────────────────────────────────
LLM_MODEL_NAME=qwen3-max
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=${DASHSCOPE_API_KEY}
LLM_TIMEOUT=30
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7
LLM_MAX_HISTORY=10

# ── TTS (DashScope Qwen3 Voice Cloning) ──────────────────────────────────────
TTS_MODEL=qwen3-tts-vc-realtime
TTS_SAMPLE_RATE=48000
TTS_MAX_TEXT_LENGTH=1000

# ── RunPod Serverless (GPU Rendering) ────────────────────────────────────────
RUNPOD_API_KEY=CHANGEME
RUNPOD_ENDPOINT_MUSETALK=CHANGEME
RUNPOD_ENDPOINT_PREPROCESS=CHANGEME

# ── Cloudflare R2 (S3-compatible Storage) ────────────────────────────────────
R2_ACCOUNT_ID=CHANGEME
R2_ACCESS_KEY_ID=CHANGEME
R2_SECRET_ACCESS_KEY=CHANGEME
R2_BUCKET=maskki-media
R2_PUBLIC_URL=CHANGEME

# ── Redis ────────────────────────────────────────────────────────────────────
# Generate a strong password: openssl rand -base64 32
REDIS_PASSWORD=CHANGEME
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_TTL=3600

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_BASE_DIR=./outputs
STORAGE_MAX_FILE_AGE_HOURS=24
STATIC_FILES_DIR=./files

# ── Avatar Clips ─────────────────────────────────────────────────────────────
CLIPS_DIR=./clips

# ── Knowledge Base (RAG) ────────────────────────────────────────────────────
KB_ENABLED=true
KB_STORAGE_DIR=./data/kb
KB_EMBEDDING_MODEL=text-embedding-v3
KB_EMBEDDING_API_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
KB_EMBEDDING_API_KEY=${DASHSCOPE_API_KEY}
KB_CHUNK_SIZE=500
KB_CHUNK_OVERLAP=50
KB_TOP_K=3
KB_CONFIDENCE_THRESHOLD=0.6

# ── Training Engine ─────────────────────────────────────────────────────────
TRAINING_ENABLED=true
TRAINING_DB_PATH=./data/training.db
TRAINING_ESCALATION_THRESHOLD=0.5
TRAINING_GO_LIVE_THRESHOLD=100.0

# ── Guardrails ───────────────────────────────────────────────────────────────
GUARDRAILS_ENABLED=true
GUARDRAILS_MAX_RESPONSE_LENGTH=2000

# ── Billing ──────────────────────────────────────────────────────────────────
BILLING_ENABLED=true
BILLING_RATE_PER_SECOND=0.002
BILLING_GRACE_PERIOD_S=5

# ── WhatsApp (Meta Business API) — optional ──────────────────────────────────
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v18.0
WHATSAPP_WEBHOOK_URL=

# ── WebRTC — optional ────────────────────────────────────────────────────────
WEBRTC_ENABLED=false
WEBRTC_STUN_SERVERS=stun:stun.l.google.com:19302

# ── AI Optimization Agent ────────────────────────────────────────────────────
AGENT_AGENT_ENABLED=true
AGENT_AUTO_FIX_ENABLED=true
AGENT_SCAN_INTERVAL_S=60
AGENT_AUDIT_LOG_PATH=/app/logs/agent_audit.jsonl
AGENT_NOTIFICATION_EMAIL_ENABLED=true
AGENT_NOTIFICATION_EMAIL_TO=contact@lsmarttech.com

# ── SMTP (email alerts) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=CHANGEME
SMTP_PASSWORD=CHANGEME
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=agent@yourdomain.com

# ── Monitoring ───────────────────────────────────────────────────────────────
# Generate a strong password: openssl rand -base64 32
GRAFANA_ADMIN_PASSWORD=CHANGEME
GRAFANA_ROOT_URL=https://yourdomain.com/grafana

# ── Deployment ───────────────────────────────────────────────────────────────
DOMAIN_NAME=yourdomain.com
SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
