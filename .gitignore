# =============================================================================
# SmartTalker — .gitignore
# =============================================================================

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
eggs/
*.egg

# ── Virtual Environment ─────────────────────────────────────────────────────
venv/
.venv/
env/

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ── Environment & Secrets — NEVER commit ─────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.staging
*.pem
*.key

# ── AI Models (large files) ─────────────────────────────────────────────────
models/*
!models/README.md
!models/**/
models/**/*
!models/**/.gitkeep
*.pt
*.pth
*.onnx
*.bin
*.safetensors
*.ckpt

# ── Generated Output ────────────────────────────────────────────────────────
outputs/*
!outputs/README.md
!outputs/**/
outputs/**/*
!outputs/**/.gitkeep
files/*
!files/.gitkeep
logs/
*.wav
*.mp3
*.ogg
*.mp4
*.avi
*.webm
*.m4a

# ── Keep avatar and voice assets ───────────────────────────────────────────
!avatars/**/*.png
!avatars/**/*.jpg
!avatars/**/*.jpeg
!avatars/**/*.webp
!voices/README.md

# ── Docker ───────────────────────────────────────────────────────────────────
.docker/

# ── Test & Coverage ──────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
test_output.txt
test_debug.log
run_tests_debug.py

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/

# ── Cloudflare ───────────────────────────────────────────────────────────────
.wrangler/

# ── Misc ─────────────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
nul
.last_agent_run
api_test_output.txt
