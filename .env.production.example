# =============================================================================
# SmartTalker — Production Environment Template
# Copy to .env.production and fill in all values
# Usage: docker compose -f docker-compose.prod.yml --env-file .env.production up -d
# =============================================================================

# === Database ===
DB_PASSWORD=                          # openssl rand -base64 32
DATABASE_URL=postgresql://smarttalker:${DB_PASSWORD}@postgres:5432/smarttalker

# === Redis ===
REDIS_PASSWORD=                       # openssl rand -base64 32
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# === DashScope (ALL AI — LLM, ASR, TTS) ===
DASHSCOPE_API_KEY=sk-___
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_WS_URL=wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime
LLM_MODEL=qwen3-max
ASR_MODEL=qwen3-asr-flash-realtime
TTS_MODEL=qwen3-tts-vc-realtime

# === RunPod ===
RUNPOD_API_KEY=rpa-___
RUNPOD_ENDPOINT_MUSETALK=https://api.runpod.ai/v2/tdc1jq3awl16oj
# Endpoint: maskki-render -fb | RTX 4090 | 3 max workers | 5s idle | FlashBoot ON

# === Cloudflare R2 ===
R2_ACCOUNT_ID=                        # Your Cloudflare account ID
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=maskki-media
R2_PUBLIC_URL=https://media.maskki.com
R2_ENDPOINT_URL=https://4d8f4f63318eba92fa502bd731eb3380.r2.cloudflarestorage.com

# === Paddle (Billing) ===
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=

# === CORS ===
CORS_ORIGINS=https://maskki.com,https://app.maskki.com,https://admin.maskki.com,https://ws.maskki.com

# === URLs ===
CENTRAL_URL=https://ws.maskki.com
API_URL=https://api.maskki.com
APP_URL=https://app.maskki.com
ADMIN_URL=https://admin.maskki.com

# === Security ===
API_KEY=                              # openssl rand -hex 32
ADMIN_API_KEY=                        # openssl rand -hex 32
JWT_SECRET=                           # openssl rand -hex 32
TESTING=0

# === Email (Resend) ===
RESEND_API_KEY=re-___

# === SMTP (AI Agent alerts) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=agent@maskki.com

# === AI Agent ===
AGENT_NOTIFICATION_EMAIL_ENABLED=true
AGENT_NOTIFICATION_EMAIL_TO=contact@maskki.com

# === Monitoring ===
GRAFANA_ADMIN_PASSWORD=               # openssl rand -base64 32
