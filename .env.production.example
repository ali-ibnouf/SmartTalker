# =============================================================================
# Maskki (SmartTalker) — Production Environment Template
# Copy to .env.production and fill in all values
# Usage: docker compose -f docker-compose.prod.yml --env-file .env.production up -d
# =============================================================================

# === General ===
APP_NAME=Maskki
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# === Security (REQUIRED) ===
API_KEY=                              # openssl rand -hex 32
ADMIN_API_KEY=                        # openssl rand -hex 32
JWT_SECRET=                           # openssl rand -hex 32
TESTING=0

# === API Server ===
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
RATE_LIMIT_PER_MINUTE=60
PIPELINE_TIMEOUT=120

# === CORS ===
CORS_ORIGINS=https://maskki.com,https://www.maskki.com,https://app.maskki.com,https://admin.maskki.com,https://ws.maskki.com

# === URLs ===
CENTRAL_URL=https://ws.maskki.com
API_URL=https://api.maskki.com
APP_URL=https://app.maskki.com
ADMIN_URL=https://admin.maskki.com
SITE_URL=https://maskki.com

# === Database ===
POSTGRES_PASSWORD=                    # openssl rand -base64 32
DATABASE_URL=postgresql+asyncpg://maskki:${POSTGRES_PASSWORD}@postgres:5432/maskki

# === Redis ===
REDIS_PASSWORD=                       # openssl rand -base64 32
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_TTL=3600

# === DashScope (ALL AI — LLM, ASR, TTS, Embeddings) ===
DASHSCOPE_API_KEY=sk-___
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_WS_URL=wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime

# === ASR ===
ASR_MODEL=qwen3-asr-flash-realtime

# === LLM ===
LLM_MODEL_NAME=qwen3-max
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=${DASHSCOPE_API_KEY}
LLM_TIMEOUT=30
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7
LLM_MAX_HISTORY=10

# === TTS ===
TTS_MODEL=qwen3-tts-vc-realtime
TTS_SAMPLE_RATE=48000
TTS_MAX_TEXT_LENGTH=1000

# === RunPod (GPU Render Nodes) ===
RUNPOD_API_KEY=rpa-___
RUNPOD_ENDPOINT_MUSETALK=https://api.runpod.ai/v2/YOUR_ENDPOINT_ID
RUNPOD_ENDPOINT_PREPROCESS=https://api.runpod.ai/v2/YOUR_ENDPOINT_ID

# === Cloudflare R2 (Media Storage) ===
R2_ACCOUNT_ID=                        # Your Cloudflare account ID
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=maskki-media
R2_PUBLIC_URL=https://media.maskki.com
R2_ENDPOINT_URL=https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com

# === Paddle (Billing) ===
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT=production

# === Storage ===
STORAGE_BACKEND=local
STORAGE_BASE_DIR=./outputs
STORAGE_MAX_FILE_AGE_HOURS=24
STATIC_FILES_DIR=./files
CLIPS_DIR=./clips

# === Knowledge Base (RAG) ===
KB_ENABLED=true
KB_STORAGE_DIR=./data/kb
KB_EMBEDDING_MODEL=text-embedding-v3
KB_EMBEDDING_API_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
KB_EMBEDDING_API_KEY=${DASHSCOPE_API_KEY}
KB_CHUNK_SIZE=500
KB_CHUNK_OVERLAP=50
KB_TOP_K=3
KB_CONFIDENCE_THRESHOLD=0.6

# === Training Engine ===
TRAINING_ENABLED=true
TRAINING_DB_PATH=./data/training.db
TRAINING_ESCALATION_THRESHOLD=0.5
TRAINING_GO_LIVE_THRESHOLD=100.0

# === Guardrails ===
GUARDRAILS_ENABLED=true
GUARDRAILS_MAX_RESPONSE_LENGTH=2000
GUARDRAILS_BLOCKED_TOPICS=
GUARDRAILS_REQUIRED_DISCLAIMERS=

# === Billing ===
BILLING_ENABLED=true
BILLING_RATE_PER_SECOND=0.002
BILLING_GRACE_PERIOD_S=5

# === Email (Resend — transactional) ===
RESEND_API_KEY=re-___

# === SMTP (AI Agent alerts) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=agent@maskki.com
SMTP_FROM_NAME=Maskki AI Agent

# === WhatsApp (optional) ===
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v18.0
WHATSAPP_WEBHOOK_URL=

# === Telegram (optional) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_URL=

# === WebRTC (optional) ===
WEBRTC_ENABLED=false
WEBRTC_STUN_SERVERS=stun:stun.l.google.com:19302
WEBRTC_TURN_SERVER=
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_PASSWORD=

# === AI Agent ===
# Note: AgentSettings uses env_prefix="AGENT_" — AGENT_ENABLED maps to agent_enabled
AGENT_ENABLED=true
AGENT_AUTO_FIX_ENABLED=true
AGENT_SCAN_INTERVAL_S=60
AGENT_AUDIT_LOG_PATH=/app/logs/agent_audit.jsonl
AGENT_NOTIFICATION_EMAIL_ENABLED=true
AGENT_NOTIFICATION_EMAIL_TO=contact@maskki.com
AGENT_NOTIFICATION_WS_ENABLED=true

# === Monitoring ===
GRAFANA_ADMIN_PASSWORD=               # openssl rand -base64 32
GRAFANA_ROOT_URL=https://ws.maskki.com/grafana

# === Deployment / SSL ===
DOMAIN_NAME=ws.maskki.com
SSL_CERT_PATH=/etc/letsencrypt/live/ws.maskki.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/ws.maskki.com/privkey.pem
